FROM ubuntu:latest

ENV DEBIAN_FRONTEND=noninteractive
ENV PATH=/root/.local/bin:/root/.opencode/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

COPY git-askpass.sh /usr/local/bin/git-askpass-opencode
COPY start-opencode.sh /usr/local/bin/start-opencode

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      bash \
      bash-completion \
      build-essential \
      ca-certificates \
      curl \
      dnsutils \
      fd-find \
      file \
      git \
      git-lfs \
      gnupg \
      iputils-ping \
      jq \
      less \
      make \
      nano \
      netcat-openbsd \
      openssh-client \
      patch \
      procps \
      psmisc \
      python3 \
      python3-pip \
      python3-venv \
      ripgrep \
      rsync \
      shellcheck \
      sudo \
      tree \
      unzip \
      vim-tiny \
      wget \
      xz-utils \
      yamllint \
      zip && \
    mkdir -p /etc/apt/keyrings && \
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | gpg --dearmor -o /etc/apt/keyrings/githubcli-archive-keyring.gpg && \
    chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      > /etc/apt/sources.list.d/github-cli.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends gh && \
    ln -sf /usr/bin/fdfind /usr/local/bin/fd && \
    git lfs install --system && \
    rm -rf /var/lib/apt/lists/*

RUN curl -fsSL https://opencode.ai/install | bash -s -- --no-modify-path && \
    ln -sf /root/.opencode/bin/opencode /usr/local/bin/opencode && \
    opencode --version

RUN curl -LsSf https://astral.sh/uv/install.sh | sh && \
    ln -sf /root/.local/bin/uv /usr/local/bin/uv && \
    ln -sf /root/.local/bin/uvx /usr/local/bin/uvx && \
    uv --version

RUN chmod +x /usr/local/bin/git-askpass-opencode /usr/local/bin/start-opencode && \
    mkdir -p /workspace /root/.ssh

WORKDIR /workspace

ENTRYPOINT ["/usr/local/bin/start-opencode"]
CMD ["--hostname", "0.0.0.0", "--port", "4096"]
