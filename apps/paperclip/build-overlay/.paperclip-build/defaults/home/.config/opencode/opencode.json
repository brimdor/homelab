{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": "allow",
    "task": "allow",
    "external_directory": {
      "/**": "allow"
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (homelab)",
      "options": {
        "baseURL": "http://ollama.ollama.svc.cluster.local:11434/v1"
      },
      "models": {
        "cody:latest": {
          "name": "cody:latest"
        },
        "echo:latest": {
          "name": "echo:latest"
        },
        "gpt-oss:20b": {
          "name": "gpt-oss:20b"
        },
        "humble:latest": {
          "name": "humble:latest"
        },
        "ministral-3:8b": {
          "name": "ministral-3:8b"
        },
        "qwen3.5:397b-cloud": {
          "name": "qwen3.5:397b-cloud"
        },
        "qwen3.5:9b": {
          "name": "qwen3.5:9b"
        },
        "qwen3.5:cloud": {
          "name": "qwen3.5:cloud"
        }
      }
    }
  }
}
